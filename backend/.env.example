PORT=5001

# PostgreSQL Direct Connection String
# Obtain from: Supabase Dashboard → Settings → Database → Connection String → Direct (not Pooler)
# Format: postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?sslmode=require
# Note: Special characters in password (e.g. @) must be URL-encoded (@ → %40)
DATABASE_URL=postgres://postgres:[your-password]@db.[your-project-id].supabase.co:5432/postgres?sslmode=require
